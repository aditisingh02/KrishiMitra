# ---- Fireworks (LLM) - required ----
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxx
# Embedding model powering the pgvector long-term memory. Must output EMBED_DIM
# dimensions - keep the two in sync if you switch models.
MODEL_EMBED=nomic-ai/nomic-embed-text-v1.5
EMBED_DIM=768

# ---- Database (PostgreSQL + pgvector) - required ----
# Render injects DATABASE_URL automatically for its managed Postgres. Locally,
# run: docker run -d --name km-pg -e POSTGRES_PASSWORD=pg -p 5432:5432 pgvector/pgvector:pg16
DATABASE_URL=postgresql://postgres:pg@localhost:5432/postgres

# ---- Real external data (no synthetic fallbacks) ----
# OpenWeather: https://openweathermap.org/api  (free tier covers forecast + geocoding)
OPENWEATHER_API_KEY=
# data.gov.in (Agmarknet daily mandi prices): https://data.gov.in (register → API key)
DATA_GOV_API_KEY=

# ---- Twilio (WhatsApp alerts + inbound Q&A) - optional ----
# From twilio.com console. For WhatsApp use the sandbox sender to start.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Point your Twilio WhatsApp "When a message comes in" webhook at:
#   https://<your-public-url>/api/whatsapp   (use ngrok in dev)
#
# Inbound requests are authenticated by their X-Twilio-Signature (HMAC of the URL
# + params using TWILIO_AUTH_TOKEN). Leave this on: with it off, anyone who finds
# the webhook URL can forge a message and impersonate any farm by phone number.
TWILIO_VALIDATE_SIGNATURE=true
# Twilio signs the exact public URL set in its console. Behind a proxy the app may
# see a different scheme/host - if validation fails, set the public URL explicitly:
#   TWILIO_WEBHOOK_URL=https://your-app.onrender.com/api/whatsapp
TWILIO_WEBHOOK_URL=

# ---- Rate limiting ----
# Protects every endpoint that spends AI credits. Keyed by Clerk user id when
# authenticated, else by client IP.
RATE_LIMIT_ENABLED=true
# Leave empty for in-memory (single instance). With more than one worker, point at
# Redis so limits are shared: RATE_LIMIT_STORAGE_URI=redis://localhost:6379
RATE_LIMIT_STORAGE_URI=
LIMIT_CONSULT=20/minute
LIMIT_DIAGNOSE=10/minute
LIMIT_SOIL_CARD=10/minute
LIMIT_MONITOR_RUN=5/minute
LIMIT_I18N=60/minute
LIMIT_WHATSAPP=60/minute

# ---- Upload guards ----
# Images are read into memory and base64'd to the vision model, so an unbounded
# upload is both an OOM risk and a large token bill.
MAX_UPLOAD_BYTES=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ---- i18n caps ----
# /api/i18n is public (the landing page needs it before sign-in) and calls the LLM
# per uncached string, so each request is bounded.
I18N_MAX_STRINGS=200
I18N_MAX_STRING_LEN=400

# ---- Autonomous monitoring ----
MONITOR_ENABLED=true
MONITOR_INTERVAL_HOURS=24

# ---- Auth (Clerk) ----
# Your Clerk instance JWT issuer, e.g. https://your-app.clerk.accounts.dev
# Find it in Clerk Dashboard → API Keys (or "Show JWT issuer URL").
CLERK_ISSUER=
# Optional (reserved for Clerk backend API calls):
CLERK_SECRET_KEY=
