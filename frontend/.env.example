# ---- Clerk (auth) - required to run ----
# From Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# Auth route config (leave as-is unless you move the pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Backend the /api/* proxy forwards to (default: http://127.0.0.1:8000)
# BACKEND_URL=http://127.0.0.1:8000
